    m_LineSpacing: 1
  m_Text: "\u041D\u043E\u0447\u044C, \u0441\u0442\u0430\u0440\u0438\u043D\u043D\u044B\u0439
    \u043E\u0441\u043E\u0431\u043D\u044F\u043A. \u0412\u043E\u0440\u0438\u0448\u043A\u0430
    \u043F\u043E \u0438\u043C\u0435\u043D\u0438 \u041B\u0435\u043A\u0441 \u0441\u0442\u043E\u0438\u0442
    \u043F\u0435\u0440\u0435\u0434 \u043C\u0430\u0441\u0441\u0438\u0432\u043D\u043E\u0439
    \u0434\u0432\u0435\u0440\u044C\u044E \u0441\u043E\u043A\u0440\u043E\u0432\u0438\u0449\u043D\u0438\u0446\u044B.
    \u0412 \u0440\u0443\u043A\u0430\u0445 \u2014 \u043D\u0430\u0431\u043E\u0440 \u043E\u0442\u043C\u044B\u0447\u0435\u043A,
    \u0432 \u0441\u0435\u0440\u0434\u0446\u0435 \u2014 \u043D\u0430\u0434\u0435\u0436\u0434\u0430."
